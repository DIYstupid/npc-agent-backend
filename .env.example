LLM_PROVIDER=openai_compatible

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
SHORT_TERM_MEMORY_MAX_MESSAGES=10

CHROMA_PERSIST_DIR=app/data/chroma
LONG_TERM_MEMORY_COLLECTION=npc_long_term_memory
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_LOCAL_FILES_ONLY=true
LONG_TERM_MEMORY_TOP_K=3

PROMPT_TOKEN_BUDGET=3000
SHORT_TERM_MEMORY_TOKEN_BUDGET=600
SUMMARY_MEMORY_TOKEN_BUDGET=350
LONG_TERM_MEMORY_TOKEN_BUDGET=700
CONTEXT_LONG_TERM_CANDIDATE_TOP_K=6
RAG_KNOWLEDGE_COLLECTION=npc_rag_knowledge
RAG_CHUNK_TOKEN_BUDGET=350
RAG_CONTEXT_TOKEN_BUDGET=600
CONTEXT_RAG_CANDIDATE_TOP_K=6
LOG_LEVEL=INFO
TRACE_DB_PATH=app/data/agent_traces.db
TRACE_MAX_RECORDS=200
LANGGRAPH_CHECKPOINT_DB_PATH=app/data/langgraph_checkpoints.db

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXCLUDED_PATHS=/health

REFLECTION_MODE=background
REFLECTION_WORKER_SHUTDOWN_TIMEOUT_SECONDS=5
